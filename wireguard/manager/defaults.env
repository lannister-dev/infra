# WireGuard infra defaults (PROD)

WG_INTERFACE=wg0
WG_PORT=443

# ДОМЕН ДЛЯ WG
WG_ENDPOINT=vpn.lannister-dev.ru

WG_IPV4_SUBNET=10.100.0.0/24

WG_ENABLE_IPV6=0

WG_MTU=1420
WG_PERSISTENT_KEEPALIVE=25

# Только infra-сеть, НЕ full tunnel
WG_CLIENT_ALLOWED_IPS=10.100.0.0/24

WG_CLIENT_DNS=

WG_ENABLE_FORWARDING=1