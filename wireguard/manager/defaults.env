# WireGuard defaults for vpn-infra (non-interactive, infra-friendly)
# You can override any of these via environment variables or by sourcing a .local file in apply.sh if you want.

# Interface name
export WG_INTERFACE="${WG_INTERFACE:-wg0}"

# WireGuard listen port (use 443 if UDP 51820 is filtered)
export WG_PORT="${WG_PORT:-443}"

# Domain endpoint for clients (IMPORTANT: domain, not IP)
# Example: vpn.lannister-dev.ru
export WG_ENDPOINT="${WG_ENDPOINT:-vpn.example.com}"

# WireGuard subnet (IPv4 only by default)
# Interface IPs are allocated from this /24:
# server will be .1, clients from .2+
export WG_IPV4_SUBNET="${WG_IPV4_SUBNET:-10.100.0.0/24}"

# Optional IPv6 (off by default)
export WG_ENABLE_IPV6="${WG_ENABLE_IPV6:-0}"
export WG_IPV6_SUBNET="${WG_IPV6_SUBNET:-fd10:100::/64}"

# MTU
export WG_MTU="${WG_MTU:-1420}"

# Keepalive for NAT traversal (clients)
export WG_PERSISTENT_KEEPALIVE="${WG_PERSISTENT_KEEPALIVE:-25}"

# AllowedIPs inside client configs:
# For site-to-site / admin tunnel обычно достаточно wg-subnet (10.100.0.0/24).
# Если тебе нужен full-tunnel — поставь 0.0.0.0/0
export WG_CLIENT_ALLOWED_IPS="${WG_CLIENT_ALLOWED_IPS:-10.100.0.0/24}"

# DNS in client config (empty => не задаём)
export WG_CLIENT_DNS="${WG_CLIENT_DNS:-}"

# Enable ip_forward (recommended when you later route other subnets via WG)
export WG_ENABLE_FORWARDING="${WG_ENABLE_FORWARDING:-1}"

# Paths
export WG_ETC_DIR="${WG_ETC_DIR:-/etc/wireguard}"
export WG_CLIENTS_DIR="${WG_CLIENTS_DIR:-/etc/wireguard/clients}"

# Backup location
export WG_BACKUP_DIR="${WG_BACKUP_DIR:-/var/backups}"
export WG_BACKUP_FILE="${WG_BACKUP_FILE:-/var/backups/wireguard-vpn-infra.zip}"