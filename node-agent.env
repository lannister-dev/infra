# -------- Agent --------
AGENT_IDENTITY_PATH=/data/node_identity.json
AGENT_NODE_KEY_PATH=/data/node_key
AGENT_INSTANCE_ID_PATH=/data/agent_instance_id
AGENT_AGENT_VERSION=1.4

AGENT_POLL_INTERVAL_S=3
AGENT_FULL_RECONCILE_EVERY_N_POLLS=40
AGENT_MAX_OPS_PER_POLL=200

# -------- Control API --------
AGENT_CONTROL_API=https://api.lannister-dev.ru/api/v1/agent
AGENT_CONTROL_API_TIMEOUT_S=8

# -------- Xray --------
AGENT_XRAY_HOST=vpn_xray
AGENT_XRAY_PORT=10085
AGENT_XRAY_TIMEOUT_S=3
AGENT_XRAY_VLESS_WS_INBOUND_TAG=vless-ws
AGENT_XRAY_VLESS_XHTTP_INBOUND_TAG=vless-xhttp
AGENT_XRAY_VLESS_TCP_INBOUND_TAG=vless-reality

# -------- Health --------
AGENT_HEALTH_HOST=0.0.0.0
AGENT_HEALTH_PORT=9000
AGENT_ENABLE_METRICS=true
