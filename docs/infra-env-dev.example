# Backend (required)
TF_STATE_BUCKET=your-state-bucket
TF_STATE_REGION=ru-central1
TF_STATE_KEY_PREFIX=vpn-infra/dev
# TF_STATE_DYNAMODB_TABLE=terraform-locks

# Terraform provider mirror (recommended in restricted regions)
# TF_PROVIDER_MIRROR_URL=https://terraform-mirror.yandexcloud.net/

# ---- Provider credentials (required only when corresponding TF root is applied) ----
# Yandex Cloud VPN nodes (terraform/yandex-vpn)
# YC_SERVICE_ACCOUNT_KEY_B64=<base64_of_authorized_key.json>
# IAC_TFVAR_YANDEX_CLOUD_ID=b1g...
# IAC_TFVAR_YANDEX_FOLDER_ID=b1g...
# Timeweb (terraform/infra-nodes)
# IAC_TFVAR_TIMEWEB_API_TOKEN=...

# ---- K8s / Helm ----

# Control plane (development)
CONTROL_PLANE_URL=https://dev-api.example.com/api/v1/artifacts
ADMIN_API_KEY=<dev_admin_token>

# Harbor registry
HARBOR_HOST=harbor.lannister-dev.ru

# Node agent images
NODE_AGENT_IMAGE_REF=harbor.lannister-dev.ru/vpn-service/node-agent:prod
NODE_AGENT_IMAGE_REF_DEV=harbor.lannister-dev.ru/vpn-service/node-agent:dev

# ---- SSH keys for Ansible / K3s node setup ----
# Consumed by the k3s-setup workflow; Ansible does not talk to VPN nodes anymore.
# ANSIBLE_SSH_KEYS_B64_JSON='{"dev":"<base64_private_key>","yc":"<base64_private_key>"}'
# ANSIBLE_SSH_PRIVATE_KEY_B64=<base64_private_key>

# Vault layout:
# kv/infra/dev field: config      -> this file content
# kv/node-agent/dev field: config -> node-agent.dev.env content
