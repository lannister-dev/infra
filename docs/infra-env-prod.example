# Backend (required)
TF_STATE_BUCKET=your-state-bucket
TF_STATE_REGION=ru-central1
TF_STATE_KEY_PREFIX=vpn-infra/prod

# Terraform provider mirror (recommended in restricted regions)
# Yandex mirror for registry.terraform.io providers:
# TF_PROVIDER_MIRROR_URL=https://terraform-mirror.yandexcloud.net/
# Alternative (advanced): pass full CLI config as text/base64
# TF_CLI_CONFIG_CONTENT=
# TF_CLI_CONFIG_CONTENT_B64=

# Backend (optional for S3-compatible/object-storage)
# TF_STATE_DYNAMODB_TABLE=terraform-locks
# TF_STATE_ENDPOINT=https://storage.yandexcloud.net
# TF_STATE_USE_PATH_STYLE=true
# TF_STATE_ACCESS_KEY=...
# TF_STATE_SECRET_KEY=...

# Foundation TF vars (required, uppercase-only alias style)
IAC_TFVAR_VPN_DOMAIN=example.com
IAC_TFVAR_VPN_WS_PATH=/api/v1/stream
IAC_TFVAR_VPN_XHTTP_PATH=/api/v1/mobile
IAC_TFVAR_VPN_REALITY_SERVER_NAME=www.cloudflare.com
IAC_TFVAR_VPN_REALITY_PRIVATE_KEY=<x25519_private_key>
IAC_TFVAR_VPN_REALITY_SHORT_ID=<short_id_hex>
IAC_TFVAR_VPN_REALITY_DEST_HOST=www.cloudflare.com

# Foundation TF vars (required toggle; dev fields are needed only when true)
IAC_TFVAR_ENABLE_VPN_DEV_STACK=false
# When IAC_TFVAR_ENABLE_VPN_DEV_STACK=true, set all dev values explicitly:
# IAC_TFVAR_VPN_DEV_DOMAIN=dev.example.com
# IAC_TFVAR_VPN_DEV_WS_PATH=/api/v1/stream
# IAC_TFVAR_VPN_DEV_XHTTP_PATH=/api/v1/mobile
# IAC_TFVAR_VPN_DEV_REALITY_SERVER_NAME=www.cloudflare.com
# IAC_TFVAR_VPN_DEV_REALITY_PRIVATE_KEY=<x25519_private_key>
# IAC_TFVAR_VPN_DEV_REALITY_SHORT_ID=<short_id_hex>
# IAC_TFVAR_VPN_DEV_REALITY_DEST_HOST=www.cloudflare.com

# Docker config names are auto-generated by Terraform using content hashes.
# No version variables needed — config names rotate automatically on file change.

# Optional output paths
# TF_VAR_inventory_output_path=
# INFRA_NODES_OUTPUT_PATH=
# INVENTORY_OUTPUT_PATH=

# ---- Provider credentials (optional; only if corresponding mode is enabled in tfvars) ----

# HostVDS / OpenStack (terraform/nodes)
# IAC_TFVAR_HOSTVDS_OS_AUTH_URL=https://os-api.hostvds.com/identity
# IAC_TFVAR_HOSTVDS_OS_USERNAME=hostvds-...
# IAC_TFVAR_HOSTVDS_OS_PASSWORD=...
# IAC_TFVAR_HOSTVDS_OS_PROJECT_NAME=hostvds-...
# IAC_TFVAR_HOSTVDS_OS_USER_DOMAIN_NAME=Default
# IAC_TFVAR_HOSTVDS_OS_USER_DOMAIN_ID=
# IAC_TFVAR_HOSTVDS_OS_PROJECT_DOMAIN_NAME=
# IAC_TFVAR_HOSTVDS_OS_PROJECT_DOMAIN_ID=default
# IAC_TFVAR_HOSTVDS_OS_REGION_NAME=eu-north1b
# IAC_TFVAR_HOSTVDS_OS_INTERFACE=public

# Runtime HostVDS credentials may still be required by other HostVDS/OpenStack operations:
# HOSTVDS_OS_AUTH_URL=https://os-api.hostvds.com/identity
# HOSTVDS_OS_USERNAME=hostvds-...
# HOSTVDS_OS_PASSWORD=...
# HOSTVDS_OS_PROJECT_NAME=hostvds-...
# HOSTVDS_OS_USER_DOMAIN_NAME=Default
# HOSTVDS_OS_PROJECT_DOMAIN_ID=default
# HOSTVDS_OS_REGION_NAME=eu-north1b
# HOSTVDS_OS_INTERFACE=public

# Yandex Cloud whitelist entry auth (terraform/nodes)
# Preferred for CI: base64-encoded authorized key JSON for a service account.
# CI materializes it into a temp file and exports TF_VAR_yandex_service_account_key_file automatically.
# YC_SERVICE_ACCOUNT_KEY_B64=<base64_of_authorized_key.json>
# Optional raw JSON variant:
# YC_SERVICE_ACCOUNT_KEY_JSON={"id":"...","service_account_id":"..."}
# Legacy short-lived fallback only:
# YC_TOKEN=...
# IAC_TFVAR_YANDEX_CLOUD_ID=b1g...
# IAC_TFVAR_YANDEX_FOLDER_ID=b1g...

# Timeweb (terraform/infra-nodes)
# IAC_TFVAR_TIMEWEB_API_URL=https://api.timeweb.cloud/api/v1
# IAC_TFVAR_TIMEWEB_API_TOKEN=...
# IAC_TFVAR_TIMEWEB_AUTH_HEADER=Authorization
# IAC_TFVAR_TIMEWEB_AUTH_SCHEME=Bearer
# IAC_TFVAR_TIMEWEB_ENDPOINT_TEMPLATE=/servers/{server_id}

# ---- Ansible runtime toggles (not Terraform vars) ----
RUN_SANITY_CHECK=true
DEPLOY_NATS_STACK=true
ENABLE_VPN_DEV_STACK=false
NATS_AUTH_TOKEN=<strong_random_token>
NATS_MONITOR_HOST=nats.example.com
NATS_MONITOR_AUTH_USERS=admin:<htpasswd_hash>
DEPLOY_DATA_PROD_STACK=false
FIREWALL_ENFORCE=false
FIREWALL_ADMIN_CIDRS=203.0.113.10/32
FIREWALL_NATS_CLIENT_CIDRS=198.51.100.20/32
# Optional:
# FIREWALL_OPEN_HTTP=true
# FIREWALL_OPEN_HTTPS=true
# FIREWALL_OPEN_NATS=true
# FIREWALL_OPEN_SWARM_PORTS=true

# Optional stack image/version env (if you manage via env)
# TRAEFIK_IMAGE_TAG=v3.6
# PROMETHEUS_IMAGE_TAG=v2.55.1
# GRAFANA_IMAGE_TAG=11.5.2
# XRAY_IMAGE_TAG=latest
# HAPROXY_ALPINE_IMAGE_TAG=3.1-alpine
# NATS_IMAGE_TAG=2.11-alpine
# NATS_EXPORTER_IMAGE_TAG=0.19.1
# VAULT_IMAGE_TAG=1.13.3
# POSTGRES_IMAGE_TAG=16-alpine
# REDIS_IMAGE_TAG=7-alpine
# DATA_PROD_NETWORK_NAME=data-prod-net

# Required only when enabled VPN nodes include traffic_role=whitelist_entry
# VPN_WHITELIST_ENTRY_UPSTREAM_HOST=203.0.113.10
# VPN_WHITELIST_ENTRY_UPSTREAM_PORT=443

# External data services precheck (leave disabled when prod data is deployed from this repo)
EXTERNAL_DATA_PRECHECK_ENABLED=false
# EXTERNAL_POSTGRES_HOST=prod-postgres.internal.example.com
# EXTERNAL_POSTGRES_PORT=5432
# EXTERNAL_REDIS_HOST=prod-redis.internal.example.com
# EXTERNAL_REDIS_PORT=6379
# EXTERNAL_DATA_PRECHECK_TIMEOUT=10

# Edge / dashboard settings
TRAEFIK_ACME_EMAIL=ops@example.com
TRAEFIK_DASHBOARD_HOST=traefik.example.com
TRAEFIK_DASHBOARD_AUTH_USERS=admin:<bcrypt_hash>
TRAEFIK_WEB_FORWARDED_HEADERS_INSECURE=false
TRAEFIK_WEBSECURE_FORWARDED_HEADERS_INSECURE=false
PROMETHEUS_HOST=prometheus.example.com
PROMETHEUS_AUTH_USERS=admin:<htpasswd_hash>
GRAFANA_HOST=grafana.example.com
# ALERTMANAGER_IMAGE_TAG=v0.27.0
# ALERTMANAGER_HOST=alertmanager.example.com
# ALERTMANAGER_AUTH_USERS=admin:<htpasswd_hash>
# ALERTMANAGER_WEBHOOK_URL=http://placeholder:5001/alert

# Managed data-prod stack
DEPLOY_DATA_PROD_STACK=true
PROD_POSTGRES_DB=vpn_control
PROD_POSTGRES_USER=vpn_prod_user
PROD_POSTGRES_PUBLISHED_PORT=15433
PROD_POSTGRES_PASSWORD=<strong_password>
PROD_REDIS_PASSWORD=<strong_password>
# Optional: pin data-prod to a specific prod manager during migration
# DATA_PROD_PLACEMENT_CONSTRAINT=node.hostname == infra-manager-02

# ---- Generic alias style (alternative to TF_VAR_*) ----
# IAC_TFVAR_HOSTVDS_OS_AUTH_URL=https://os-api.hostvds.com/identity
# IAC_TFVAR_TIMEWEB_API_TOKEN=...

# ---- SSH keys for Ansible reconcile/deploy ----
# Recommended multi-key map (node selects by ssh_key_ref):
# ANSIBLE_SSH_KEYS_B64_JSON='{"dev":"<base64_private_key>","yc":"<base64_private_key>","backup":"<base64_private_key>"}'
# Backward-compatible single-key options:
# ANSIBLE_SSH_PRIVATE_KEY_B64=<base64_private_key>
# ANSIBLE_SSH_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----..
# ANSIBLE_SSH_PRIVATE_KEY_FILE=/home/github-runner/.ssh/dev

# ---- Vault layout ----
# kv/infra/prod field: config      -> this file content
# kv/node-agent/prod field: config -> node-agent.env content
