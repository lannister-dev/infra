listen: ":${HY2_LISTEN_PORT}"

tls:
  certFile: /etc/hysteria/cert.pem
  keyFile: /etc/hysteria/key.pem

auth:
  type: password
  password:
    - ${HY2_AUTH_PASSWORD}

obfs:
  type: salamander
  salamander:
    password: ${HY2_OBFS_PASSWORD}

quic:
  initStreamReceiveWindow: 8388608
  maxStreamReceiveWindow: 8388608
  initConnReceiveWindow: 20971520
  maxConnReceiveWindow: 20971520

bandwidth:
  up: 100 mbps
  down: 100 mbps

disableUDP: false