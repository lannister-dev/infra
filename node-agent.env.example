# -------- Agent --------
AGENT_IDENTITY_PATH=/data/node_identity.json
AGENT_NODE_KEY_PATH=/data/node_key
AGENT_INSTANCE_ID_PATH=/data/agent_instance_id
AGENT_APPLIED_STATE_PATH=/data/applied_inventory.json
AGENT_VERSION=dev

AGENT_TRAFFIC_INTERVAL_S=30
AGENT_POLL_INTERVAL_S=3
AGENT_FULL_RECONCILE_EVERY_N_POLLS=40
AGENT_MAX_OPS_PER_POLL=200

# -------- Control API --------
AGENT_CONTROL_API=https://dev-api.example.com/api/v1/agent
AGENT_CONTROL_API_TIMEOUT_S=8

# -------- Xray --------
AGENT_XRAY_HOST=vpn-dev_xray
AGENT_XRAY_PORT=10085
AGENT_XRAY_TIMEOUT_S=3
AGENT_XRAY_VLESS_WS_INBOUND_TAG=vless-ws
AGENT_XRAY_VLESS_XHTTP_INBOUND_TAG=vless-xhttp
AGENT_XRAY_VLESS_TCP_INBOUND_TAG=vless-tcp
AGENT_XRAY_VLESS_REALITY_INBOUND_TAG=vless-reality

# -------- Node Identity --------
# Runtime AGENT_NODE_KEY should match the system hostname.
# In this repo the stacks inject:
# AGENT_NODE_KEY={{.Node.Hostname}}

# -------- NATS --------
# Internal Swarm route:
# NATS_SERVER=nats://<NATS_AUTH_TOKEN>@nats:4222
#
# External route via Traefik TCP:
# NATS_SERVER=nats://<NATS_AUTH_TOKEN>@nats.example.com:4222
NATS_SERVER=nats://replace_with_nats_auth_token@nats.example.com:4222
NATS_NAME=node-agent-dev
NATS_RECONNECT_TIME_WAIT=2
NATS_RECONNECT_ATTEMPTS=-1
NATS_TRAFFIC_SUBJECT=users.traffic

# -------- Health --------
AGENT_HEALTH_HOST=0.0.0.0
AGENT_HEALTH_PORT=9000
AGENT_ENABLE_METRICS=true
