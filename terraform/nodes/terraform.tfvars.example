# Safety guard: keep false for normal runs.
# Set true only for intentional full decommission.
# allow_empty_vpn_nodes = false

# Optional provider API enrichment and compute provisioning.
# provider_api_enabled    = false  # legacy switch (auto-enabled when provider_api_vpn_nodes is not empty)
# hostvds_compute_enabled = false  # legacy switch (auto-enabled when provider_compute_vpn_nodes is not empty)
#
# NOTE: In this root module provider=hostvds is currently implemented.
# Additional providers should follow modules/provider-template contract.
#
# HostVDS OpenStack credentials (use HOSTVDS_OS_* in .env/CI and map to TF_VAR_hostvds_os_*):
# hostvds_os_auth_url = "https://<keystone-host>/identity/v3"
# hostvds_os_username = "hostvds-..."
# hostvds_os_password = "..."
# hostvds_os_project_name = "..."
# hostvds_os_user_domain_name = "Default"
# hostvds_os_user_domain_id = ""
# hostvds_os_project_domain_name = "Default"
# hostvds_os_project_domain_id = "default"
# hostvds_os_region_name = ""
# hostvds_os_interface = "public"
#
# provider_api_vpn_nodes = {
#   "vpn-hv-main-01" = {
#     provider  = "hostvds"
#     server_id = "98765"
#     channel   = "prod"
#     ssh_user  = "root"
#     ssh_port  = 22
#     enabled   = true
#     region    = "de-fra"
#   }
# }

