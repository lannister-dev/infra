#     ssh_user    = "root"
#     ssh_port    = 22
#     ssh_key_ref = "default"
#     enabled     = true
#     region      = "eu-west2"
#   }
# }

# Yandex Cloud credentials (optional when YC_TOKEN / YC_CLOUD_ID / YC_FOLDER_ID are already exported):
# yandex_token = "..."
# yandex_cloud_id = "b1g..."
# yandex_folder_id = "b1g..."
# yandex_zone = "ru-central1-a"
#
# Existing Yandex Cloud whitelist entry nodes adopted by import:
